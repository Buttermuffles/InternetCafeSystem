# API URL (leave empty if using Vite proxy, or set to full server URL)
# Development with Vite proxy:
VITE_API_URL=

# Production or direct connection:
# VITE_API_URL=http://192.168.1.2:8080

# API Key for authentication
VITE_API_KEY=icafe-monitor-api-key-2024-secure-token-abc123xyz

# Realtime (Soketi / Pusher protocol)
VITE_PUSHER_APP_KEY=icafe-key
VITE_PUSHER_APP_CLUSTER=mt1
VITE_PUSHER_PORT=6001
VITE_PUSHER_HOST=
